<!-- Header — Minimal editorial nav -->
<header class="header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="logo">
        <img src="/images/logo.png" alt="Osborne Electric & Contracting" class="logo-img">
        <div class="logo-text">
          <span class="logo-name">OSBORNE</span>
          <span class="logo-tagline">ELECTRIC + CONTRACTING</span>
        </div>
      </a>

      <nav class="main-nav" aria-label="Main navigation">
        <ul>
          <li><a href="/"{% if page.url == "/" %} class="active"{% endif %}>Home</a></li>
          <li class="nav-dropdown">
            <a href="/services/"{% if page.url and "/services/" in page.url %} class="active"{% endif %}>Services</a>
            <div class="nav-dropdown-content">
              <a href="/services/residential-electrical/">Residential Electrical</a>
              <a href="/services/remodels-new-construction/">Remodels & New Construction</a>
              <a href="/services/lighting-installation/">Lighting Installation</a>
              <a href="/services/panel-upgrades/">Panel Upgrades</a>
              <a href="/services/power-restoration/">Power Restoration</a>
            </div>
          </li>
          <li class="nav-dropdown">
            <a href="/areas/"{% if page.url and "/areas/" in page.url %} class="active"{% endif %}>Service Areas</a>
            <div class="nav-dropdown-content">
              <a href="/areas/salt-lake-county/">Salt Lake County</a>
              <a href="/areas/utah-county/">Utah County</a>
              <a href="/areas/davis-county/">Davis County</a>
              <a href="/areas/tooele-county/">Tooele County</a>
              <a href="/areas/summit-county/">Summit County</a>
            </div>
          </li>
          <li><a href="/about/"{% if page.url == "/about/" %} class="active"{% endif %}>About</a></li>
          <li><a href="/contact/"{% if page.url == "/contact/" %} class="active"{% endif %}>Contact</a></li>
        </ul>
      </nav>

      <a href="/contact/" class="header-cta">
        <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Get Free Estimate
      </a>

      <button class="nav-toggle" aria-label="Toggle navigation" onclick="document.querySelector('.main-nav').classList.toggle('active')">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>
