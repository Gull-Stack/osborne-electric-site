---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- for page in collections.all %}
{%- if page.url and page.url != "/sitemap.xml" %}
  <url>
    <loc>https://osborne-electric.com{{ page.url }}</loc>
    <lastmod>{{ page.date | date: "%Y-%m-%d" }}</lastmod>
    <changefreq>{%- if page.url == "/" %}weekly{%- elif "/services/" in page.url %}monthly{%- elif "/areas/" in page.url %}monthly{%- elif "/guides/" in page.url %}monthly{%- else %}monthly{%- endif %}</changefreq>
    <priority>{%- if page.url == "/" %}1.0{%- elif page.url == "/services/" or page.url == "/about/" or page.url == "/contact/" %}0.9{%- elif "/services/" in page.url %}0.8{%- elif page.url == "/areas/" %}0.8{%- elif "/areas/" in page.url %}0.7{%- elif "/guides/" in page.url %}0.7{%- else %}0.5{%- endif %}</priority>
  </url>
{%- endif %}
{%- endfor %}
</urlset>
