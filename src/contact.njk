---
title: "Contact Us | Osborne Electric | Free Estimate Utah"
description: "Contact Osborne Electric for a free electrical estimate. Licensed Master Electricians serving Salt Lake, Utah, Davis, Tooele & Summit Counties. Call 801-885-4521."
---
{% extends "base.njk" %}

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "mainEntity": {
    "@type": "ElectricalContractor",
    "name": "Osborne Electric & Contracting",
    "telephone": "+1-801-885-4521",
    "email": "Osborne-electric@outlook.com",
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "07:00",
        "closes": "18:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "08:00",
        "closes": "14:00"
      }
    ]
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://osborne-electric.com/"},
    {"@type": "ListItem", "position": 2, "name": "Contact"}
  ]
}
</script>
{% endblock %}

{% block content %}
<!-- Hero -->
<section class="service-hero">
  <div class="hero-bg" style="background-image: url('/images/work/project-05.jpg')"></div>
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span> Contact
    </nav>
    <h1>Contact Us</h1>
    <p>Get in touch for a free estimate on your electrical project</p>
  </div>
</section>

<!-- Contact Grid -->
<section class="content-section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <h2>Get in Touch</h2>
        <p>Ready to discuss your electrical project? We're here to help. Reach out by phone, email, or fill out the form and we'll get back to you promptly.</p>

        <div class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h4>Phone</h4>
            <p><a href="tel:801-885-4521">801-885-4521</a></p>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <h4>Email</h4>
            <p><a href="mailto:Osborne-electric@outlook.com">Osborne-electric@outlook.com</a></p>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          </div>
          <div>
            <h4>Hours</h4>
            <p>Monday - Friday: 7:00 AM - 6:00 PM<br>Saturday: 8:00 AM - 2:00 PM<br>Sunday: Closed</p>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h4>Service Areas</h4>
            <p><a href="/areas/salt-lake-county/">Salt Lake County</a><br><a href="/areas/utah-county/">Utah County</a><br><a href="/areas/davis-county/">Davis County</a><br><a href="/areas/tooele-county/">Tooele County</a><br><a href="/areas/summit-county/">Summit County</a></p>
          </div>
        </div>

        <div class="social-links mt-2">
          <a href="https://www.facebook.com/profile.php?id=100078333527371" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/osborne.electric" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        </div>
      </div>

      <div class="contact-form">
        <h2>Request a Free Quote</h2>
        <form action="/api/contact" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Your Name *</label>
              <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required>
            </div>
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email">
          </div>

          <div class="form-group">
            <label for="city">City/Area</label>
            <input type="text" id="city" name="city" placeholder="e.g., Salt Lake City, Provo">
          </div>

          <div class="form-group">
            <label for="service">Service Needed</label>
            <select id="service" name="service">
              <option value="">Select a service...</option>
              <option value="residential">Residential Electrical</option>
              <option value="remodel">Remodel / New Construction</option>
              <option value="lighting">Lighting Installation</option>
              <option value="panel">Panel Upgrade</option>
              <option value="power">Power Restoration / Emergency</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Tell Us About Your Project *</label>
            <textarea id="message" name="message" required placeholder="Please describe what you need help with..."></textarea>
          </div>

          <!-- Honeypot spam protection -->
          <div style="position: absolute; left: -9999px;" aria-hidden="true">
            <input type="text" name="fax_number" tabindex="-1" autocomplete="off">
          </div>

          <!-- Timestamp token (bot detection) -->
          <input type="hidden" name="_timestamp" id="_timestamp" value="">

          <button type="submit" class="btn btn-primary" style="width:100%">Send Message</button>
        </form>
        <script>document.getElementById('_timestamp').value = Date.now();</script>
      </div>
    </div>
  </div>
</section>

<!-- Service Areas -->
<section class="content-section alt-bg">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Service Areas</span>
      <h2>We Serve the Entire Wasatch Front</h2>
      <p>Professional electrical services across 5 Utah counties.</p>
    </div>

    <div class="areas-grid">
      <a href="/areas/salt-lake-county/" class="area-card">
        <h3>Salt Lake County</h3>
        <p>Salt Lake City, Sandy, Draper, Murray, West Valley & more</p>
      </a>
      <a href="/areas/utah-county/" class="area-card">
        <h3>Utah County</h3>
        <p>Provo, Orem, Lehi, American Fork & more</p>
      </a>
      <a href="/areas/davis-county/" class="area-card">
        <h3>Davis County</h3>
        <p>Bountiful, Layton, Farmington & more</p>
      </a>
      <a href="/areas/tooele-county/" class="area-card">
        <h3>Tooele County</h3>
        <p>Tooele, Grantsville, Stansbury Park & more</p>
      </a>
      <a href="/areas/summit-county/" class="area-card">
        <h3>Summit County</h3>
        <p>Park City, Coalville, Kamas & more</p>
      </a>
    </div>
  </div>
</section>
{% endblock %}
